# --- Secrets (NEVER commit these) -------------------------------------------
.env
.env.local
.env.*.local
*.pem
*.key
*.pfx
*.p12
keystore/
secrets/
mnemonic.txt

# --- Rust / smart contract ---------------------------------------------------
target/
**/*.rs.bk
*.pdb
# Build artifacts (regenerated by `ksc all build`). The reference ABI under
# contracts/*/abi/ is committed on purpose; output/ is not.
output/
wasm/
*.wasm

# --- Node / frontend ---------------------------------------------------------
node_modules/
dist/
.vite/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# --- Editors / OS ------------------------------------------------------------
.idea/
# Personal Claude Code settings (machine-local). The shared .claude/settings.json
# (if any) is fine to commit; the *.local.json variant is not.
.claude/settings.local.json
# Ignore personal VS Code state, but SHARE the project config that makes
# rust-analyzer discover the contract crates (see .vscode/settings.json).
.vscode/*
!.vscode/settings.json
!.vscode/extensions.json
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Misc --------------------------------------------------------------------
*.log
*.tmp
*.temp
coverage/
