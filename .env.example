# ----------------------------------------------------------------------------
# Example environment for klever-academy-intro-class
#
# Copy this file to `.env` and fill in YOUR values:
#     cp .env.example .env
#
# `.env` is git-ignored. NEVER commit real keys or mnemonics.
# Use a dedicated TESTNET wallet for class.
# ----------------------------------------------------------------------------

# --- Network ----------------------------------------------------------------
# One of: mainnet | testnet | devnet | local   (use testnet for class)
NETWORK=testnet

# Node URL used by koperator (deploy/invoke).
#   mainnet: https://node.mainnet.klever.org
#   testnet: https://node.testnet.klever.org
#   local:   http://localhost:8080
KLEVER_NODE=https://node.testnet.klever.org

# API URL used by query scripts (read-only /sc/query).
#   mainnet: https://api.mainnet.klever.org
#   testnet: https://api.testnet.klever.org
API_URL=https://api.testnet.klever.org

# --- Klever SDK paths -------------------------------------------------------
# Where the Klever SDK was installed (from https://install.klever.org).
KLEVER_SDK_PATH=$HOME/klever-sdk

# --- Wallet -----------------------------------------------------------------
# Path to your wallet key file (PEM). PLACEHOLDER — point to your own file.
# This file is git-ignored. Do NOT commit it.
KEY_FILE=$HOME/klever-sdk/walletKey.pem

# Private key for scripts/interact.ts (Node.js). PLACEHOLDER.
# Leave empty to run interact.ts in read-only mode.
# NEVER use a wallet that holds real funds.
PRIVATE_KEY=

# --- Contract ---------------------------------------------------------------
# Filled in AFTER you deploy (printed by ./scripts/deploy.sh).
CONTRACT_ADDRESS=klv1qqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqqq_REPLACE_ME

# Optional: a default student address for interact.ts examples.
STUDENT_ADDRESS=
